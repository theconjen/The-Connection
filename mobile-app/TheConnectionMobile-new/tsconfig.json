{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "strict": false,
    "noImplicitAny": false,
    "baseUrl": ".",
    "types": [
      "react-native"
    ]
  },
  "include": [
    "app/**/*",
    "src/**/*",
    "global.d.ts",
    "../../packages/shared/src/mobile-web/**/*"
  ],
  "exclude": [
    "node_modules",
    "../../packages/ui/src/**/*"
  ],
  "extends": "expo/tsconfig.base"
}
